{
  "name": "ton-better-auth",
  "version": "0.1.0",
  "description": "Better Auth plugin for TON Connect — sign in with TON wallets using ton_proof.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "ton",
    "ton-connect",
    "tonconnect",
    "tonkeeper",
    "wallet",
    "web3",
    "authentication",
    "ton_proof",
    "siwt"
  ],
  "author": "MonoBit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhbdev/ton-better-auth.git"
  },
  "bugs": {
    "url": "https://github.com/mhbdev/ton-better-auth/issues"
  },
  "homepage": "https://github.com/mhbdev/ton-better-auth#readme",
  "peerDependencies": {
    "@better-auth/core": ">=1.3.0",
    "better-auth": ">=1.3.0"
  },
  "dependencies": {
    "@ton/core": "^0.63.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.2",
    "tweetnacl": "^1.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
